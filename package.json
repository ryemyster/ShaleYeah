{
	"name": "shale-yeah",
	"version": "2.0.0",
	"description": "Agent OS for oil & gas investment analysis — 14 MCP servers with kernel-based discovery, parallel execution, and composition",
	"private": false,
	"type": "module",
	"main": "dist/main.js",
	"scripts": {
		"build": "tsc",
		"build:mcp": "tsc",
		"build:watch": "tsc --watch",
		"dev": "NODE_ENV=development tsx src/main.ts --mode=demo",
		"start": "NODE_ENV=production tsx src/main.ts",
		"init": "npx claude-flow@alpha init",
		"gen": "tsx scripts/generate-from-spec.ts",
		"demo": "npx tsx src/demo-runner.ts",
		"prod": "npx tsx src/main.ts --mode=production",
		"analyze": "npx tsx src/main.ts",
		"pipeline": "npx tsx src/main.ts",
		"pipeline:demo": "npx tsx src/demo-runner.ts",
		"pipeline:prod": "npx tsx src/main.ts --mode=production",
		"pipeline:batch": "npx tsx src/main.ts --mode=batch",
		"pipeline:research": "npx tsx src/main.ts --mode=research",
		"lint": "biome check .",
		"type-check": "tsc --noEmit",
		"clean": "npm run clean:dist && npm run clean:cache && npm run clean:demo",
		"clean:dist": "rm -rf dist/",
		"clean:cache": "rm -rf node_modules/.cache .tsx-cache",
		"clean:demo": "bash scripts/cleanup-workspace.sh",
		"clean:outputs": "rm -rf outputs/*",
		"clean:autogen": "rm -rf .claude-flow/ .hive-mind/ dist/ outputs/ tests/mcp-test-outputs/ tests/temp/",
		"clean:repo-push": "npm run clean && npm run clean:outputs && rm -rf node_modules/",
		"clean:all": "npm run clean && npm run clean:outputs && rm -rf node_modules/ package-lock.json",
		"clean:workspace": "bash scripts/cleanup-workspace.sh",
		"test": "npm run test:demo && npm run test:files && npm run test:mcp && npm run test:processors && npm run test:main && npm run test:mcp-infrastructure && npm run test:mcp-domain-servers && npm run test:remaining-tools && npm run test:final-integration && npm run test:mcp-client-modes && npm run test:llm-client && npm run test:kernel-registry && npm run test:kernel-executor && npm run test:kernel-context && npm run test:kernel-output && npm run test:kernel-resilience && npm run test:kernel-auth && npm run test:kernel-audit && npm run test:kernel-bundles && npm run test:kernel-monte-carlo && npm run test:market-eia && npm run test:kernel-health-monitor && npm run test:kernel-result-cache && npm run test:kernel-session-persistence && npm run test:kernel-cancellation && npm run test:kernel-timeout-boundary && npm run test:kernel-graceful-degradation && npm run test:kernel-partial-success && npm run test:geowiz-anti-stub && npm run test:econobot-anti-stub && npm run test:curve-smith-anti-stub && npm run test:risk-analysis-anti-stub && npm run test:decision-anti-stub && npm run test:reporter-anti-stub && npm run test:support-servers-anti-stub && npm run test:demo-fixture-injection",
		"test:decision-anti-stub": "npx tsx tests/decision-anti-stub.test.ts",
		"test:reporter-anti-stub": "npx tsx tests/reporter-anti-stub.test.ts",
		"test:support-servers-anti-stub": "npx tsx tests/support-servers-anti-stub.test.ts",
		"test:risk-analysis-anti-stub": "npx tsx tests/risk-analysis-anti-stub.test.ts",
		"test:demo-fixture-injection": "npx tsx tests/demo-fixture-injection.test.ts",
		"test:econobot-anti-stub": "npx tsx tests/econobot-anti-stub.test.ts",
		"test:curve-smith-anti-stub": "npx tsx tests/curve-smith-anti-stub.test.ts",
		"test:geowiz-anti-stub": "npx tsx tests/geowiz-anti-stub.test.ts",
		"test:kernel-partial-success": "npx tsx tests/kernel-partial-success.test.ts",
		"test:kernel-graceful-degradation": "npx tsx tests/kernel-graceful-degradation.test.ts",
		"test:kernel-timeout-boundary": "npx tsx tests/kernel-timeout-boundary.test.ts",
		"test:kernel-cancellation": "npx tsx tests/kernel-cancellation.test.ts",
		"test:kernel-session-persistence": "npx tsx tests/kernel-session-persistence.test.ts",
		"test:kernel-result-cache": "npx tsx tests/kernel-result-cache.test.ts",
		"test:kernel-health-monitor": "npx tsx tests/kernel-health-monitor.test.ts",
		"test:market-eia": "npx tsx tests/market-eia.test.ts",
		"test:kernel-monte-carlo": "npx tsx tests/kernel-monte-carlo.test.ts",
		"test:demo": "npx tsx tests/demo.test.ts",
		"test:files": "npx tsx tests/file-formats.test.ts",
		"test:mcp": "npx tsx tests/mcp-simple.test.ts",
		"test:processors": "npx tsx tests/file-processors.test.ts",
		"test:main": "npx tsx tests/main.test.ts",
		"test:mcp-infrastructure": "npx tsx tests/mcp-server-infrastructure-mock.test.ts",
		"test:mcp-domain-servers": "npx tsx tests/mcp-domain-servers.test.ts",
		"test:remaining-tools": "npx tsx tests/remaining-tools.test.ts",
		"test:final-integration": "npx tsx tests/final-integration.test.ts",
		"test:mcp-client-modes": "npx tsx tests/mcp-client-modes.test.ts",
		"test:llm-client": "npx tsx tests/llm-client.test.ts",
		"test:kernel-registry": "npx tsx tests/kernel-registry.test.ts",
		"test:kernel-executor": "npx tsx tests/kernel-executor.test.ts",
		"test:kernel-context": "npx tsx tests/kernel-context.test.ts",
		"test:kernel-output": "npx tsx tests/kernel-output.test.ts",
		"test:kernel-resilience": "npx tsx tests/kernel-resilience.test.ts",
		"test:kernel-auth": "npx tsx tests/kernel-auth.test.ts",
		"test:kernel-audit": "npx tsx tests/kernel-audit.test.ts",
		"test:kernel-bundles": "npx tsx tests/kernel-bundles.test.ts",
		"test:all": "npm run test",
		"test:coverage": "npm run test",
		"server:geowiz": "npx tsx src/servers/geowiz.ts",
		"server:econobot": "npx tsx src/servers/econobot.ts",
		"server:curve-smith": "npx tsx src/servers/curve-smith.ts",
		"server:reporter": "npx tsx src/servers/reporter.ts",
		"server:decision": "npx tsx src/servers/decision.ts",
		"server:research": "npx tsx src/servers/research.ts",
		"server:risk-analysis": "npx tsx src/servers/risk-analysis.ts",
		"server:legal": "npx tsx src/servers/legal.ts",
		"server:market": "npx tsx src/servers/market.ts",
		"server:development": "npx tsx src/servers/development.ts",
		"server:drilling": "npx tsx src/servers/drilling.ts",
		"server:infrastructure": "npx tsx src/servers/infrastructure.ts",
		"server:title": "npx tsx src/servers/title.ts",
		"server:test": "npx tsx src/servers/test.ts"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.82.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@turf/turf": "^7.3.4",
		"dotenv": "^17.4.1",
		"glob": "^13.0.3",
		"openai": "^6.33.0",
		"proj4": "^2.20.8",
		"shapefile": "^0.6.6",
		"exceljs": "^4.4.0",
		"xml2js": "^0.6.2",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
